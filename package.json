{
  "name": "voidtools-everything-mcp",
  "version": "0.1.0",
  "description": "MCP server for searching a local voidtools Everything index.",
  "type": "module",
  "bin": {
    "voidtools-everything-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.11"
  },
  "keywords": [
    "mcp",
    "everything",
    "voidtools",
    "search"
  ],
  "license": "MIT"
}
